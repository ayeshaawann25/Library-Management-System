using System;
using System.Data;
using Microsoft.Data.SqlClient;
using System.Windows.Forms;

namespace LibraryManagementSystem
{
    public partial class Form3 : Form
    {
        private readonly string connectionString =
            @"Data Source=.\SQLEXPRESS;Initial Catalog=LibraryDB;
              Integrated Security=True;TrustServerCertificate=True";

        public Form3()
        {
            InitializeComponent();

            btnSave.Click += btnSave_Click;
            btnUpdate.Click += btnUpdate_Click;
            btnDelete.Click += btnDelete_Click;
            dgvMembers.DoubleClick += dgvMembers_DoubleClick;
            txtSearch.TextChanged += txtSearch_TextChanged;

            LoadMembers();
        }

        private void LoadMembers(string search = "")
        {
            string query = "SELECT MemberId, FullName, Email, Phone, Address, MembershipDate FROM Members";
            if (!string.IsNullOrWhiteSpace(search))
                query += " WHERE FullName LIKE @search OR Email LIKE @search OR Phone LIKE @search";

            using SqlConnection con = new SqlConnection(connectionString);
            using SqlDataAdapter da = new SqlDataAdapter(query, con);

            if (!string.IsNullOrWhiteSpace(search))
                da.SelectCommand.Parameters.AddWithValue("@search", "%" + search + "%");

            DataTable dt = new DataTable();
            da.Fill(dt);
            dgvMembers.DataSource = dt;
        }

        private bool ValidateInput()
        {
            if (string.IsNullOrWhiteSpace(txtFullName.Text))
            { MessageBox.Show("Please enter full name.", "Validation Error", MessageBoxButtons.OK, MessageBoxIcon.Warning); return false; }
            if (string.IsNullOrWhiteSpace(txtEmail.Text))
            { MessageBox.Show("Please enter email.", "Validation Error", MessageBoxButtons.OK, MessageBoxIcon.Warning); return false; }
            if (string.IsNullOrWhiteSpace(txtPhone.Text))
            { MessageBox.Show("Please enter phone number.", "Validation Error", MessageBoxButtons.OK, MessageBoxIcon.Warning); return false; }
            return true;
        }

        private void btnSave_Click(object sender, EventArgs e)
        {
            if (!ValidateInput()) return;

            try
            {
                using SqlConnection con = new SqlConnection(connectionString);
                using SqlCommand cmd = new SqlCommand(
                    @"INSERT INTO Members (FullName, Email, Phone, Address, MembershipDate)
                      VALUES (@name, @email, @phone, @address, @date)", con);

                cmd.Parameters.AddWithValue("@name", txtFullName.Text);
                cmd.Parameters.AddWithValue("@email", txtEmail.Text);
                cmd.Parameters.AddWithValue("@phone", txtPhone.Text);
                cmd.Parameters.AddWithValue("@address", txtAddress.Text);
                cmd.Parameters.AddWithValue("@date", dtpMembership.Value);

                con.Open();
                cmd.ExecuteNonQuery();
                LoadMembers();
                ClearFields();
                MessageBox.Show("Member added successfully!", "Success", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error: {ex.Message}", "Database Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private void btnUpdate_Click(object sender, EventArgs e)
        {
            if (dgvMembers.SelectedRows.Count == 0)
            { MessageBox.Show("Please select a member to update.", "Warning", MessageBoxButtons.OK, MessageBoxIcon.Warning); return; }
            if (!ValidateInput()) return;

            try
            {
                int id = Convert.ToInt32(dgvMembers.SelectedRows[0].Cells["MemberId"].Value);

                using SqlConnection con = new SqlConnection(connectionString);
                using SqlCommand cmd = new SqlCommand(
                    @"UPDATE Members SET FullName=@name, Email=@email, Phone=@phone,
                      Address=@address, MembershipDate=@date WHERE MemberId=@id", con);

                cmd.Parameters.AddWithValue("@name", txtFullName.Text);
                cmd.Parameters.AddWithValue("@email", txtEmail.Text);
                cmd.Parameters.AddWithValue("@phone", txtPhone.Text);
                cmd.Parameters.AddWithValue("@address", txtAddress.Text);
                cmd.Parameters.AddWithValue("@date", dtpMembership.Value);
                cmd.Parameters.AddWithValue("@id", id);

                con.Open();
                cmd.ExecuteNonQuery();
                LoadMembers();
                ClearFields();
                MessageBox.Show("Member updated successfully!", "Success", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error: {ex.Message}", "Database Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private void btnDelete_Click(object sender, EventArgs e)
        {
            if (dgvMembers.SelectedRows.Count == 0)
            { MessageBox.Show("Please select a member to delete.", "Warning", MessageBoxButtons.OK, MessageBoxIcon.Warning); return; }

            if (MessageBox.Show("Are you sure you want to delete this member?",
                "Confirm Delete", MessageBoxButtons.YesNo, MessageBoxIcon.Warning) == DialogResult.No)
                return;

            try
            {
                int id = Convert.ToInt32(dgvMembers.SelectedRows[0].Cells["MemberId"].Value);

                using SqlConnection con = new SqlConnection(connectionString);
                using SqlCommand cmd = new SqlCommand("DELETE FROM Members WHERE MemberId=@id", con);

                cmd.Parameters.AddWithValue("@id", id);
                con.Open();
                cmd.ExecuteNonQuery();
                LoadMembers();
                ClearFields();
                MessageBox.Show("Member deleted successfully!", "Success", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error: {ex.Message}", "Database Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private void dgvMembers_DoubleClick(object sender, EventArgs e)
        {
            if (dgvMembers.SelectedRows.Count == 0) return;

            var r = dgvMembers.SelectedRows[0];
            txtFullName.Text = r.Cells["FullName"].Value.ToString();
            txtEmail.Text = r.Cells["Email"].Value.ToString();
            txtPhone.Text = r.Cells["Phone"].Value.ToString();
            txtAddress.Text = r.Cells["Address"].Value.ToString();
            dtpMembership.Value = Convert.ToDateTime(r.Cells["MembershipDate"].Value);
        }

        private void txtSearch_TextChanged(object sender, EventArgs e)
        {
            LoadMembers(txtSearch.Text);
        }

        private void ClearFields()
        {
            txtFullName.Clear();
            txtEmail.Clear();
            txtPhone.Clear();
            txtAddress.Clear();
            dtpMembership.Value = DateTime.Now;
        }
    }
}
